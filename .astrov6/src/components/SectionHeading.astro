---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  description2?: string;
  align?: "left" | "center";
  light?: boolean;
  class?: string;
}
const { eyebrow, title, description, description2, align = "center", light = false, class: className = "" } = Astro.props;
const alignCls = align === "center" ? "mx-auto text-center" : "text-left";
const eyebrowJustify = align === "center" ? "justify-center" : "";
const titleColor = light ? "text-primary-foreground" : "text-primary";
const descColor = light ? "text-primary-foreground/80" : "text-muted-foreground";
---
<div class:list={["max-w-3xl", alignCls, className]}>
  {eyebrow && (
    <div class:list={["flex items-center gap-3 mb-4", eyebrowJustify]}>
      <span class="w-8 h-[2px] bg-accent"></span>
      <span class="text-xs uppercase tracking-[0.25em] text-accent font-semibold">{eyebrow}</span>
      <span class="w-8 h-[2px] bg-accent"></span>
    </div>
  )}
  <h2 class:list={["font-serif text-3xl sm:text-4xl lg:text-5xl font-semibold leading-tight", titleColor]}>{title}</h2>
  {description && <p class:list={["mt-5 text-base sm:text-lg leading-relaxed", descColor]}>{description}</p>}
  {description2 && <p class:list={["mt-4 text-base sm:text-lg leading-relaxed", descColor]}>{description2}</p>}
</div>
