---
import { Icon } from "astro-icon/components";
import SectionHeading from "../SectionHeading.astro";
const advantages = [
  { icon: "lucide:piggy-bank", title: "Cost Savings", desc: "Independent oversight reduces costs by keeping the project aligned with budget, schedule, and scope." },
  { icon: "lucide:award", title: "Expert Management", desc: "We manage oversight of your project ensuring seamless flow and completion. Working exclusively for you — not the contractor or developer." },
  { icon: "lucide:compass", title: "Direct Control", desc: "You stay informed and in command. We translate the complexities and present clear, actionable choices." },
  { icon: "lucide:clock", title: "Rapid Completion", desc: "Proactive scheduling, vendor coordination, and issue resolution keep your project moving — and on time." },
  { icon: "lucide:shield-check", title: "Stress Reduction", desc: "We handle the meetings, paperwork, and problem-solving so you can relax." },
  { icon: "lucide:message-square", title: "Transparent Communication", desc: "Regular reports, photos, and direct access. You always know exactly where your project stands." },
];
---
<section class="py-20 lg:py-28 bg-background">
  <div class="container-prose">
    <SectionHeading
      eyebrow="Why SWFL Solutions"
      title="The Advantage of True Owner Advocacy"
      description="When your representative answers only to you, every decision is made with your best interest in mind."
    />
    <div class="mt-16 grid sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
      {advantages.map((a) => (
        <div class="flex gap-5">
          <div class="shrink-0 w-12 h-12 rounded-md bg-gradient-gold flex items-center justify-center shadow-gold">
            <Icon name={a.icon} class="w-6 h-6 text-accent-foreground" />
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-primary mb-2">{a.title}</h3>
            <p class="text-muted-foreground leading-relaxed text-sm">{a.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
