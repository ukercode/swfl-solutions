---
import { Icon } from "astro-icon/components";
const year = new Date().getFullYear();
---
<footer class="bg-primary text-primary-foreground">
  <div class="container-prose py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
    <div class="lg:col-span-1">
      <a href="/" class="font-serif text-2xl font-semibold">
        SWFL <span class="text-accent">Solutions</span>
      </a>
      <p class="mt-4 text-sm text-primary-foreground/75 leading-relaxed">
        Trusted Owner Representation in Southwest Florida.
      </p>
      <div class="mt-6 inline-block w-12 h-[2px] bg-accent"></div>
    </div>

    <div>
      <h4 class="font-serif text-lg mb-4 text-accent">Services</h4>
      <ul class="space-y-2 text-sm text-primary-foreground/80">
        <li><a href="/services" class="hover:text-accent transition-colors">Owner Representation</a></li>
        <li><a href="/services" class="hover:text-accent transition-colors">Project Management</a></li>
        <li><a href="/services" class="hover:text-accent transition-colors">Project Recovery</a></li>
        <li><a href="/services" class="hover:text-accent transition-colors">Construction Oversight</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-serif text-lg mb-4 text-accent">Company</h4>
      <ul class="space-y-2 text-sm text-primary-foreground/80">
        <li><a href="/about" class="hover:text-accent transition-colors">About Us</a></li>
        <li><a href="/services" class="hover:text-accent transition-colors">Our Services</a></li>
        <li><a href="/contact" class="hover:text-accent transition-colors">Contact</a></li>
        <li><a href="/contact" class="hover:text-accent transition-colors">Free Consultation</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-serif text-lg mb-4 text-accent">Contact</h4>
      <ul class="space-y-3 text-sm text-primary-foreground/80">
        <li class="flex items-start gap-3">
          <Icon name="lucide:phone" class="w-4 h-4 mt-0.5 text-accent shrink-0" />
          <a href="tel:9412495750" class="hover:text-accent transition-colors">941-249-5750</a>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="lucide:mail" class="w-4 h-4 mt-0.5 text-accent shrink-0" />
          <a href="mailto:office@swflsolutions.com" class="hover:text-accent transition-colors break-all">
            office@swflsolutions.com
          </a>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="lucide:map-pin" class="w-4 h-4 mt-0.5 text-accent shrink-0" />
          <span>Englewood, FL 34224</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-primary-foreground/15">
    <div class="container-prose py-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-primary-foreground/60">
      <p>© {year} Southwest Florida Solutions LLC. All rights reserved.</p>
      <p>Professional · Experienced · Insured · Exclusively on Your Side</p>
    </div>
  </div>
</footer>
